# =============================================================================
# SECTION 4 -- STUDENT REPORT CARDS
# Grade cells: bold grade letter + italic descriptor, colour by grade band
# =============================================================================
doc.addHeading("Section 4: Student Report Cards", 1)
doc.addParagraph(
    "Each subject cell contains a bold grade letter + italic descriptor in the " +
    "same cell. The overall result cell is large, bold, and colour-coded by grade. " +
    "The comment cell uses three runs: label bold, body regular, signed italic.", NULL)
doc.addEmptyParagraph()

doc.setMergeTemplate([
    [:type = "heading", :level = 2, :text = "{{StudentName}}  --  {{Programme}}"],
    [:type = "table",
     :data = [
         # Header row
         ["Subject", "Grade", "Mark", "Comments"],
         # Subject rows -- grade cell has two runs
         [
             "Mathematics",
             mergeCell([
                 [:text = "{{MathGrade}}",     :bold = true,   :size = 26, :color = "{{MathGradeColor}}"],
                 [:text = " {{MathDesc}}",     :italic = true, :size = 18, :color = "444444"]
             ], [:align = "center"]),
             mergeCell([[:text = "{{MathMark}}%", :bold = true, :color = "{{MathGradeColor}}"]], [:align = "center"]),
             "{{MathComment}}"
         ],
         [
             "Ring Programming",
             mergeCell([
                 [:text = "{{RingGrade}}",     :bold = true,   :size = 26, :color = "{{RingGradeColor}}"],
                 [:text = " {{RingDesc}}",     :italic = true, :size = 18, :color = "444444"]
             ], [:align = "center"]),
             mergeCell([[:text = "{{RingMark}}%", :bold = true, :color = "{{RingGradeColor}}"]], [:align = "center"]),
             "{{RingComment}}"
         ],
         [
             "Compiler Design",
             mergeCell([
                 [:text = "{{CompGrade}}",     :bold = true,   :size = 26, :color = "{{CompGradeColor}}"],
                 [:text = " {{CompDesc}}",     :italic = true, :size = 18, :color = "444444"]
             ], [:align = "center"]),
             mergeCell([[:text = "{{CompMark}}%", :bold = true, :color = "{{CompGradeColor}}"]], [:align = "center"]),
             "{{CompComment}}"
         ],
         [
             "Visual Programming",
             mergeCell([
                 [:text = "{{VisPGrade}}",     :bold = true,   :size = 26, :color = "{{VisPGradeColor}}"],
                 [:text = " {{VisPDesc}}",     :italic = true, :size = 18, :color = "444444"]
             ], [:align = "center"]),
             mergeCell([[:text = "{{VisPMark}}%", :bold = true, :color = "{{VisPGradeColor}}"]], [:align = "center"]),
             "{{VisPComment}}"
         ],
         # Overall result row
         [
             mergeCell([[:text = "Overall Result", :bold = true, :color = "FFFFFF"]], [:bgColor = "1F3864", :colspan = 2]),
             mergeCell([
                 [:text = "{{OverallGrade}}",   :bold = true, :size = 30, :color = "{{OverallColor}}"],
                 [:text = "  {{OverallDesc}}",  :italic = true, :size = 18, :color = "FFFFFF"]
             ], [:bgColor = "1F3864", :align = "center"]),
             mergeCell([[:text = "{{OverallAvg}}%", :bold = true, :size = 26, :color = "{{OverallColor}}"]], [:bgColor = "1F3864", :align = "center"])
         ],
         # Tutor comment row
         [
             mergeCell([
                 [:text = "Tutor Comment: ", :bold = true,   :color = "1F3864"],
                 [:text = "{{TutorComment}}", :bold = false, :color = "000000"],
                 [:text = "  -- {{TutorName}}", :italic = true, :size = 18, :color = "666666"]
             ], [:colspan = 4])
         ]
     ],
     :options = [
         :headerRow = true, :headerBgColor = "2E75B6",
         :borderStyle = "single", :borderColor = "CCCCCC",
         :colWidths = [3.5, 2.5, 2.0, 8.0]
     ]],
    [:type = "emptyline"]
])

