doc.clearMergeTemplate()

doc.addPageBreak()

# =============================================================================
# SECTION 5 -- API REFERENCE CARDS (mixed font sizes + token fills)
# Demonstrates mixing plain cells and rich cells in the same table
# =============================================================================
doc.addHeading("Section 5: API Reference Cards", 1)
doc.addParagraph(
    "Each card documents one function. The function signature cell uses " +
    "a monospace bold run for the name and a regular run for the parameters. " +
    "The returns cell has a bold type prefix followed by a description. " +
    "Plain string cells are used for fields that need no mixed formatting.", NULL)
doc.addEmptyParagraph()

doc.setMergeTemplate([
    [:type = "table",
     :data = [
         # Function signature header -- full-width
         [
             mergeCell([
                 [:text = "{{FuncName}}",   :bold = true,   :font = "Courier New", :size = 26, :color = "FFFFFF"],
                 [:text = "( {{Params}} )", :bold = false,  :font = "Courier New", :size = 22, :color = "BDD7EE"]
             ], [:bgColor = "1F3864", :colspan = 2, :verticalAlign = "center"])
         ],
         # Module + Added in
         [
             mergeCell([
                 [:text = "Module:  ",     :bold = true,  :color = "1F3864"],
                 [:text = "{{Module}}",    :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Added in:  ",  :bold = true,  :color = "1F3864"],
                 [:text = "v{{AddedIn}}", :bold = false, :color = "000000"]
             ], [])
         ],
         # Description -- full width, plain
         [
             mergeCell([
                 [:text = "Description:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{Description}}", :bold = false, :color = "000000"]
             ], [:colspan = 2])
         ],
         # Parameters
         [
             mergeCell([
                 [:text = "Parameters:", :bold = true, :color = "1F3864"]
             ], [:colspan = 2, :bgColor = "EEF3FA"])
         ],
         [
             mergeCell([
                 [:text = "{{P1Name}}",  :bold = true,   :font = "Courier New", :color = "C00000"],
                 [:text = "  --  ", :bold = false, :color = "888888"],
                 [:text = "{{P1Desc}}", :bold = false, :color = "000000"]
             ], [:colspan = 2])
         ],
         [
             mergeCell([
                 [:text = "{{P2Name}}",  :bold = true,   :font = "Courier New", :color = "C00000"],
                 [:text = "  --  ", :bold = false, :color = "888888"],
                 [:text = "{{P2Desc}}", :bold = false, :color = "000000"]
             ], [:colspan = 2])
         ],
         # Returns
         [
             mergeCell([
                 [:text = "Returns:  ",   :bold = true,  :color = "1F3864"],
                 [:text = "{{RetType}}",  :bold = true,  :font = "Courier New", :color = "7F3F00"],
                 [:text = "  --  {{RetDesc}}", :bold = false, :color = "000000"]
             ], [:colspan = 2])
         ],
         # Example -- full width code cell
         [
             mergeCell([
                 [:text = "Example:  ", :bold = true,  :color = "1F3864"]
             ], [:colspan = 2, :bgColor = "EEF3FA"])
         ],
         [
             mergeCell([
                 [:text = "{{Example}}", :font = "Courier New", :size = 18, :color = "1A1A2E"]
             ], [:colspan = 2, :bgColor = "EEF3FA"])
         ]
     ],
     :options = [
         :borderStyle = "single", :borderColor = "CCCCCC",
         :colWidths   = [8.0, 8.0]
     ]],
    [:type = "emptyline"]
])

apiFunctions = [
    [:FuncName    = "setMergeTemplate",
     :Params      = "templateDef",
     :Module      = "WordWriter (mail merge)",
     :AddedIn     = "1.12.4",
     :Description = "Register a document template for repeated mail-merge output. " +
                    "The template is a list of items; each item is a plain string or " +
                    "an associative list describing a heading, paragraph, table, etc.",
     :P1Name      = "templateDef",
     :P1Desc      = "List of template items. Strings are paragraphs; lists must have :type key.",
     :P2Name      = "(none)",
     :P2Desc      = "This function takes only one parameter.",
     :RetType      = "self",
     :RetDesc      = "Returns the WordWriter instance for method chaining.",
     :Example      = "doc.setMergeTemplate([" +
                     "    " + char(34) + "Dear {{Name}}," + char(34) + "," +
                     "    [:type=" + char(34) + "paragraph" + char(34) + ", :text=" + char(34) + "Your score is {{Score}}." + char(34) + "]" +
                     "])"],

    [:FuncName    = "mergeCell",
     :Params      = "runs, cellOptions",
     :Module      = "Global helper (mail merge)",
     :AddedIn     = "1.12.5",
     :Description = "Create a WordCell with multiple styled text runs for use inside " +
                    "mail-merge table templates. {{FIELD}} tokens in any run are filled " +
                    "automatically when mergeRecord() or mergeAll() is called.",
     :P1Name      = "runs",
     :P1Desc      = "List of run definitions. Each: [:text=, :bold=, :italic=, :color=, :size=, :font=, ...]",
     :P2Name      = "cellOptions",
     :P2Desc      = "Cell-level options: [:align=, :bgColor=, :verticalAlign=, :colspan=, :rowspan=]",
     :RetType      = "WordCell",
     :RetDesc      = "A fully configured WordCell ready for use in a table data array.",
     :Example      = "mergeCell([" +
                     "    [:text=" + char(34) + "Score: " + char(34) + ", :bold=true, :color=" + char(34) + "1F3864" + char(34) + "]," +
                     "    [:text=" + char(34) + "{{Score}}" + char(34) + ", :bold=true, :color=" + char(34) + "375623" + char(34) + "]" +
                     "], [:align=" + char(34) + "center" + char(34) + "])"],

    [:FuncName    = "mergeAll",
     :Params      = "dataList, separator",
     :Module      = "WordWriter (mail merge)",
     :AddedIn     = "1.12.4",
     :Description = "Render the registered template once per record in dataList, " +
                    "inserting a separator between records. The most efficient way " +
                    "to produce batch personalised documents.",
     :P1Name      = "dataList",
     :P1Desc      = "List of associative lists. Each list is one merge record.",
     :P2Name      = "separator",
     :P2Desc      = char(34) + "pagebreak" + char(34) + " (default) | " +
                    char(34) + "emptyline" + char(34) + " | " +
                    char(34) + "line" + char(34) + " | " +
                    char(34) + "none" + char(34),
     :RetType      = "self",
     :RetDesc      = "Returns the WordWriter instance for method chaining.",
     :Example      = "doc.mergeAll([" +
                     "    [:Name=" + char(34) + "Alice" + char(34) + ", :Score=" + char(34) + "94" + char(34) + "]," +
                     "    [:Name=" + char(34) + "Bob" + char(34) + ",   :Score=" + char(34) + "78" + char(34) + "]" +
                     "], " + char(34) + "pagebreak" + char(34) + ")"]
]

doc.mergeAll(apiFunctions, "emptyline")
doc.clearMergeTemplate()

# ---- Save -------------------------------------------------------------------
? "Building document ..."
doc.save("demo_mailmerge2_cells_output.docx")
? "Done -- demo_mailmerge2_cells_output.docx"
