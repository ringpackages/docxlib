/*
	DOCXLib - Demo (MailMerge2)
*/

load "docxlib.ring"

/*
    Rich Table Cells in Mail Merge Templates

      mergeCell(runs, cellOptions)
        Create a WordCell with multiple styled runs for use inside merge
        templates. {{FIELD}} tokens in run text are filled automatically
        when mergeRecord() / mergeAll() is called.

      mergeFillWordCell(cellObj, data)   [internal, used automatically]
        Clones a WordCell, filling {{FIELD}} tokens in every run while
        preserving all run-level formatting (bold, color, italic, size, etc.)

      mergeFillTable() upgraded
        Now detects WordCell objects in table data and routes them through
        mergeFillWordCell() instead of plain string coercion.

    This means a merge table cell can have:
      - Multiple runs with independent formatting
      - Bold labels + regular values in the same cell
      - Colour-coded values
      - Mixed font sizes
      - Any combination of run properties
      ...all driven by {{FIELD}} tokens that are filled per record.

*/


? "==================================================="
? "  DOCXLib -- Rich Merge Cells Demo"
? "==================================================="
? ""

doc = new WordWriter()
doc.setTitle("DOCXLib -- Rich Table Cells in Merge Templates")
doc.setAuthor("DOCXLib Demo")
doc.setPageSize("a4")
doc.setTheme("Blue")
doc.setHeader("DOCXLib -- Rich Merge Cells")
doc.setFooter("Generated by DOCXLib")

# =============================================================================
# SECTION 1 -- THE PROBLEM: plain strings lose formatting
# =============================================================================
doc.addHeading("Section 1: Why Rich Merge Cells Are Needed", 1)
doc.addParagraph(
    "In early development stage, every cell in a merge table template had to be a plain " +
    "string. That meant you could not have, for example, a bold label followed " +
    "by a regular value inside the same cell, or a colour-coded numeric result. " +
    "The entire cell was either styled or unstyled -- you could not mix.", NULL)
doc.addEmptyParagraph()
doc.addParagraph(
    "During development we provided an update that solves this with mergeCell(runs, cellOptions). Pass a list of " +
    "run definitions -- each with its own :text, :bold, :color, :italic, " +
    ":size etc. -- and {{FIELD}} tokens inside any run are filled " +
    "automatically when the template is merged.", NULL)
doc.addEmptyParagraph()
doc.addPageBreak()

# =============================================================================
# SECTION 2 -- EMPLOYEE PROFILE CARDS
# Each card: header cell spanning columns, then label+value pairs where
# the label is bold/dark and the value is regular, all in one cell.
# =============================================================================
doc.addHeading("Section 2: Employee Profile Cards", 1)
doc.addParagraph(
    "Each card uses mergeCell() to put a bold label and a regular value " +
    "in the same cell. The Status cell is colour-coded: green for Active, " +
    "amber for On Leave, red for Terminated -- the colour comes from a " +
    ":bgColor field in the data record.", NULL)
doc.addEmptyParagraph()

doc.setMergeTemplate([
    # Full-width header row: Name + title on one bold run, department on a smaller run
    [:type = "table",
     :data = [
         [
             mergeCell([
                 [:text = "{{FullName}}", :bold = true,   :size = 28, :color = "FFFFFF"],
                 [:text = "  --  ",       :bold = false,  :size = 20, :color = "BDD7EE"],
                 [:text = "{{Title}}",    :italic = true, :size = 20, :color = "BDD7EE"]
             ], [:bgColor = "1F3864", :colspan = 4, :verticalAlign = "center"])
         ],
         # Row 2: Employee ID | Department
         [
             mergeCell([
                 [:text = "Employee ID:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{EmployeeID}}",  :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Department:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{Department}}", :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Location:  ",  :bold = true,  :color = "1F3864"],
                 [:text = "{{Location}}", :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Start Date:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{StartDate}}", :bold = false, :color = "000000"]
             ], [])
         ],
         # Row 3: Email | Phone | Salary | Status (colour-coded)
         [
             mergeCell([
                 [:text = "Email:  ",  :bold = true,  :color = "1F3864"],
                 [:text = "{{Email}}", :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Phone:  ",  :bold = true,  :color = "1F3864"],
                 [:text = "{{Phone}}", :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Salary:  ",  :bold = true,  :color = "1F3864"],
                 [:text = "{{Salary}}", :bold = false, :color = "375623"]
             ], []),
             mergeCell([
                 [:text = "Status: ",    :bold = true,  :color = "FFFFFF"],
                 [:text = "{{Status}}",  :bold = true,  :color = "FFFFFF"]
             ], [:bgColor = "{{StatusBg}}", :align = "center"])
         ]
     ],
     :options = [
         :borderStyle = "single", :borderColor = "CCCCCC",
         :colWidths   = [4.0, 4.0, 4.0, 4.0],
         :repeatHeader = false
     ]],
    [:type = "emptyline"]
])

