doc.clearMergeTemplate()

doc.addPageBreak()

# =============================================================================
# SECTION 3 -- INVOICE LINE ITEMS with rich totals row
# Bold labels on header cells, colour-coded total row, mixed sizes
# =============================================================================
doc.addHeading("Section 3: Invoices with Rich Line-Item Tables", 1)
doc.addParagraph(
    "The invoice header uses mergeCell() for bold label + value pairs. " +
    "The totals row uses large bold text with a dark background. " +
    "Individual line-item description cells contain a bold product name " +
    "followed by a smaller italic description on a second run.", NULL)
doc.addEmptyParagraph()

doc.setMergeTemplate([
    # Invoice title bar
    [:type = "table",
     :data = [
         [
             mergeCell([
                 [:text = "INVOICE", :bold = true, :size = 36, :color = "FFFFFF"]
             ], [:bgColor = "1F3864", :colspan = 2, :align = "left", :verticalAlign = "center"]),
             mergeCell([
                 [:text = "{{CompanyName}}", :bold = true,   :size = 22, :color = "FFFFFF"],
                 [:text =  +"{{CompanyTag}}", :italic = true, :size = 18, :color = "BDD7EE"]
             ], [:bgColor = "1F3864", :colspan = 2, :align = "right", :verticalAlign = "center"])
         ],
         # Invoice metadata row
         [
             mergeCell([
                 [:text = "Invoice No:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{InvNum}}",    :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Date:  ",    :bold = true,  :color = "1F3864"],
                 [:text = "{{InvDate}}",:bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Due Date:  ", :bold = true,  :color = "1F3864"],
                 [:text = "{{DueDate}}", :bold = false, :color = "000000"]
             ], []),
             mergeCell([
                 [:text = "Bill To:  ",      :bold = true,  :color = "1F3864"],
                 [:text = "{{ClientName}}", :bold = false, :color = "000000"]
             ], [])
         ]
     ],
     :options = [:borderStyle = "single", :borderColor = "CCCCCC",
                 :colWidths = [4.0, 4.0, 4.0, 4.0]]],

    [:type = "emptyline"],

    # Line items table
    [:type = "table",
     :data = [
         # Header row (plain strings are fine for static labels)
         ["Description", "Qty", "Unit Price", "Amount"],
         # Line items with rich description cells
         [
             mergeCell([
                 [:text = "{{L1Name}}",  :bold = true,   :color = "000000"],
                 [:text = " -- {{L1Desc}}", :italic = true, :size = 18, :color = "666666"]
             ], []),
             "{{L1Qty}}", "{{L1Price}}", "{{L1Amount}}"
         ],
         [
             mergeCell([
                 [:text = "{{L2Name}}",  :bold = true,   :color = "000000"],
                 [:text = " -- {{L2Desc}}", :italic = true, :size = 18, :color = "666666"]
             ], []),
             "{{L2Qty}}", "{{L2Price}}", "{{L2Amount}}"
         ],
         [
             mergeCell([
                 [:text = "{{L3Name}}",  :bold = true,   :color = "000000"],
                 [:text = " -- {{L3Desc}}", :italic = true, :size = 18, :color = "666666"]
             ], []),
             "{{L3Qty}}", "{{L3Price}}", "{{L3Amount}}"
         ],
         # Subtotal / tax rows
         ["", "", mergeCell([[:text = "Subtotal:", :bold = true]], [:align = "right"]),
                  mergeCell([[:text = "{{Subtotal}}",:bold = false]], [])],
         ["", "", mergeCell([[:text = "Tax (15%):", :bold = true]], [:align = "right"]),
                  mergeCell([[:text = "{{Tax}}",:bold = false]], [])],
         # Total row: large bold white on dark background
         [
             mergeCell([
                 [:text = "TOTAL DUE", :bold = true, :size = 26, :color = "FFFFFF"]
             ], [:bgColor = "1F3864", :colspan = 3, :align = "right", :verticalAlign = "center"]),
             mergeCell([
                 [:text = "{{Total}}", :bold = true, :size = 26, :color = "FFFFFF"]
             ], [:bgColor = "1F3864", :align = "center", :verticalAlign = "center"])
         ]
     ],
     :options = [
         :headerRow = true, :headerBgColor = "2E75B6",
         :borderStyle = "single", :borderColor = "CCCCCC",
         :colWidths   = [8.5, 1.5, 3.0, 3.0]
     ]],
    [:type = "emptyline"]
])

